---
interface Props {
  href: string;
}

const { href } = Astro.props as Props;

let safeHref = "#";
let openInNewTab = false;

if (
  href.startsWith("/") ||
  href.startsWith("#") ||
  href.startsWith("./") ||
  href.startsWith("../")
) {
  safeHref = href;
} else {
  try {
    const parsedHref = new URL(href);

    if (parsedHref.protocol === "https:" || parsedHref.protocol === "http:") {
      safeHref = href;
      openInNewTab = true;
    } else if (parsedHref.protocol === "mailto:" || parsedHref.protocol === "tel:") {
      safeHref = href;
    }
  } catch {
    safeHref = "#";
  }
}
---

<a
  class="rounded-full border border-white/10 flex justify-center items-center gap-x-2 py-1 px-2
  md:py-2 md:px-4 text-xs md:text-base bg-white/5 hover:scale-110 hover:bg-white/10 transition"
  href={safeHref}
  target={openInNewTab ? "_blank" : undefined}
  rel={openInNewTab ? "noopener noreferrer" : undefined}
>
  <slot />
</a>
